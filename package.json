{
  "name": "focus-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "seed": "MONGODB_URI=$(grep MONGODB_URI apps/web/.env.local | cut -d= -f2-) npx tsx scripts/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^20.19.37",
    "tsx": "^4.21.0",
    "turbo": "latest"
  }
}
